{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense", "transfer", "investment"] },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "canceled"] },
        "cardId": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "category", "date"]
    },
    "Card": {
      "title": "Card",
      "description": "Credit or debit card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "bank": { "type": "string" },
        "color": { "type": "string" },
        "brand": { "type": "string" },
        "limit": { "type": "number" },
        "bestDay": { "type": "number" },
        "dueDay": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "bank", "color", "limit"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Financial goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "category": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "targetAmount", "currentAmount"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "AI assistant chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message in a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "List of transactions"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "User credit cards"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Financial goals"
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "AI chat history sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session"
    }
  }
}
