rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 200
        && (data.displayName == null || data.displayName is string)
        && (data.photoURL == null || data.photoURL is string);
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.amount is number
        && data.type in ['income', 'expense', 'transfer', 'investment']
        && data.category is string && data.category.size() <= 50
        && (data.cardId == null || isValidId(data.cardId))
        && data.createdAt == request.time
        && data.keys().hasAll(['userId', 'amount', 'type', 'category', 'date', 'createdAt'])
        && data.keys().size() >= 6;
    }

    function isUpdateValidTransaction(data, prev) {
      return data.userId == prev.userId
        && data.amount is number
        && data.type in ['income', 'expense', 'transfer', 'investment']
        && data.category is string && data.category.size() <= 50
        && data.updatedAt == request.time
        && data.createdAt == prev.createdAt;
    }

    function isValidCard(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 50
        && data.bank is string && data.bank.size() <= 50
        && data.limit is number
        && data.keys().hasAll(['userId', 'name', 'bank', 'limit'])
        && data.keys().size() >= 4;
    }

    function isValidGoal(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.targetAmount is number
        && data.currentAmount is number
        && data.keys().hasAll(['userId', 'name', 'targetAmount', 'currentAmount']);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming()) && isValidId(transactionId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isUpdateValidTransaction(incoming(), existing());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /cards/{cardId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCard(incoming()) && isValidId(cardId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidCard(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /goals/{goalId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidGoal(incoming()) && isValidId(goalId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidGoal(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(chatId);
      allow update: if isSignedIn() && isOwner(existing().userId) 
        && incoming().userId == existing().userId;
      
      match /messages/{messageId} {
        allow list, get: if isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.userId);
        allow create: if isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.userId)
          && incoming().role in ['user', 'assistant'];
      }
    }
  }
}
